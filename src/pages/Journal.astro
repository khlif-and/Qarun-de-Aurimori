---
import Footer from "../components/organisms/Footer.astro";
import Layout from "../layouts/Layout.astro";


---

<Layout>
  <main class="min-h-screen bg-[#f8f9fb] pt-32 md:pt-40 pb-32">
    <section class="w-full px-8 md:px-16 lg:px-24 max-w-[1200px] mx-auto flex flex-col items-center">
      
      <div class="flex flex-col w-full mb-16">
        <h1 
          class="text-6xl md:text-7xl lg:text-[84px] text-[#161f33] tracking-tight mb-8"
          style="font-family: 'Playfair Display', serif;"
        >
          The Journal
        </h1>

        <div class="w-20 h-[2px] bg-[#a9d1df] mb-8"></div>

        <p 
          class="text-[#8ba4b5] italic text-lg md:text-[22px] font-light"
          style="font-family: 'Playfair Display', serif;"
        >
          Design for the Senses
        </p>
      </div>

      <nav class="relative flex flex-wrap items-center w-full gap-8 md:gap-12">
        <div class="relative flex flex-col items-center">
          <a href="#" class="text-[10px] md:text-[11px] font-bold tracking-[0.2em] text-[#161f33] uppercase pb-4">
            ALL
          </a>
          <div class="absolute bottom-0 w-full h-[2px] bg-[#3cbce6] z-10"></div>
        </div>

        <a href="#" class="text-[10px] md:text-[11px] font-bold tracking-[0.2em] text-[#94a3b8] hover:text-[#161f33] uppercase pb-4 transition-colors duration-300">
          ARCHITECTURE
        </a>
        <a href="#" class="text-[10px] md:text-[11px] font-bold tracking-[0.2em] text-[#94a3b8] hover:text-[#161f33] uppercase pb-4 transition-colors duration-300">
          POETRY
        </a>
        <a href="#" class="text-[10px] md:text-[11px] font-bold tracking-[0.2em] text-[#94a3b8] hover:text-[#161f33] uppercase pb-4 transition-colors duration-300">
          ATMOSPHERE
        </a>

        <div class="absolute bottom-0 left-0 w-full h-[1px] bg-[#e2e8f0]"></div>
      </nav>

      <div class="w-full mt-20 lg:mt-24 grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-20 mb-24">
        
        <div class="flex flex-col gap-16 lg:gap-24">
          <a href="/journal/1" class="flex flex-col group cursor-pointer block">
          <article class="flex flex-col w-full">
            <div class="w-full overflow-hidden mb-8 bg-slate-100 rounded-lg">
              <img 
                src="https://images.unsplash.com/photo-1513694203232-719a280e022f?q=80&w=800&auto=format&fit=crop" 
                alt="The Silence of Stone" 
                class="w-full aspect-square md:aspect-[4/5] object-cover group-hover:scale-105 transition-transform duration-700 ease-out" 
              />
            </div>
            <span class="text-[#8ba4b5] text-[9px] md:text-[10px] font-bold tracking-[0.2em] uppercase mb-4">
              October 24, 2023
            </span>
            <h2 
              class="text-3xl md:text-[34px] text-[#161f33] mb-4 group-hover:text-[#3cbce6] transition-colors"
              style="font-family: 'Playfair Display', serif;"
            >
              The Silence of Stone
            </h2>
            <p class="text-[#8ba4b5] text-[14px] leading-[1.7] font-light mb-6 pr-4">
              An exploration of architectural stillness and the weight of history in contemporary brutalist structures.
            </p>
            <div class="flex items-center gap-2 text-[10px] font-bold tracking-[0.2em] text-[#161f33] uppercase group-hover:text-[#3cbce6] transition-colors">
              Read Journal
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </article>

          <a href="/journal/2" class="flex flex-col group cursor-pointer block">
          <article class="flex flex-col w-full">
            <div class="w-full overflow-hidden mb-8 bg-slate-100 rounded-lg">
              <img 
                src="https://images.unsplash.com/photo-1615873968403-89e068629265?q=80&w=800&auto=format&fit=crop" 
                alt="Light and Shadow" 
                class="w-full aspect-[3/4] object-cover group-hover:scale-105 transition-transform duration-700 ease-out" 
              />
            </div>
            <span class="text-[#8ba4b5] text-[9px] md:text-[10px] font-bold tracking-[0.2em] uppercase mb-4">
              October 12, 2023
            </span>
            <h2 
              class="text-3xl md:text-[34px] text-[#161f33] mb-4 group-hover:text-[#3cbce6] transition-colors"
              style="font-family: 'Playfair Display', serif;"
            >
              Light and Shadow
            </h2>
            <p class="text-[#8ba4b5] text-[14px] leading-[1.7] font-light mb-6 pr-4">
              Capturing the ephemeral dance of sunbeams on minimalist surfaces at the golden hour.
            </p>
            <div class="flex items-center gap-2 text-[10px] font-bold tracking-[0.2em] text-[#161f33] uppercase group-hover:text-[#3cbce6] transition-colors">
              Read Journal
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </article>
          </a>
        </div>

        <div class="flex flex-col gap-16 lg:gap-24 md:pt-24 lg:pt-32">
          <a href="/journal/3" class="flex flex-col group cursor-pointer block">
          <article class="flex flex-col w-full">
            <div class="w-full overflow-hidden mb-8 bg-slate-100 rounded-lg">
              <img 
                src="https://images.unsplash.com/photo-1574169208507-84376144848b?q=80&w=800&auto=format&fit=crop" 
                alt="Echoes of Ivory" 
                class="w-full aspect-[4/5] object-cover group-hover:scale-105 transition-transform duration-700 ease-out" 
              />
            </div>
            <span class="text-[#8ba4b5] text-[9px] md:text-[10px] font-bold tracking-[0.2em] uppercase mb-4">
              October 18, 2023
            </span>
            <h2 
              class="text-3xl md:text-[34px] text-[#161f33] mb-4 group-hover:text-[#3cbce6] transition-colors"
              style="font-family: 'Playfair Display', serif;"
            >
              Echoes of Ivory
            </h2>
            <p class="text-[#8ba4b5] text-[14px] leading-[1.7] font-light mb-6 pr-4">
              The soft resonance of monochrome textures and how they shape our perception of intimate spaces.
            </p>
            <div class="flex items-center gap-2 text-[10px] font-bold tracking-[0.2em] text-[#161f33] uppercase group-hover:text-[#3cbce6] transition-colors">
              Read Journal
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </article>
          </a>

          <a href="/journal/4" class="flex flex-col group cursor-pointer block">
          <article class="flex flex-col w-full">
            <div class="w-full overflow-hidden mb-8 bg-slate-100 rounded-lg">
              <img 
                src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?q=80&w=800&auto=format&fit=crop" 
                alt="A Pearly Morning" 
                class="w-full aspect-square object-cover group-hover:scale-105 transition-transform duration-700 ease-out" 
              />
            </div>
            <span class="text-[#8ba4b5] text-[9px] md:text-[10px] font-bold tracking-[0.2em] uppercase mb-4">
              October 05, 2023
            </span>
            <h2 
              class="text-3xl md:text-[34px] text-[#161f33] mb-4 group-hover:text-[#3cbce6] transition-colors"
              style="font-family: 'Playfair Display', serif;"
            >
              A Pearly Morning
            </h2>
            <p class="text-[#8ba4b5] text-[14px] leading-[1.7] font-light mb-6 pr-4">
              A poetic study on the iridescence of dawn and tactile luxury in everyday objects.
            </p>
            <div class="flex items-center gap-2 text-[10px] font-bold tracking-[0.2em] text-[#161f33] uppercase group-hover:text-[#3cbce6] transition-colors">
              Read Journal
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
              </svg>
            </div>
          </article>
          </a>
        </div>
      </div>
      
      <div class="flex items-center gap-4 text-[13px] font-bold text-[#475569]">
        <a href="#" class="w-10 h-10 flex items-center justify-center rounded-xl border border-[#e2e8f0] bg-white text-[#94a3b8] hover:border-[#cbd5e1] hover:text-[#475569] transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
          </svg>
        </a>

        <a href="#" class="w-10 h-10 flex items-center justify-center rounded-xl bg-[#29b2df] text-white">
          1
        </a>

        <a href="#" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-white hover:border hover:border-[#e2e8f0] transition-all">
          2
        </a>
        <a href="#" class="w-10 h-10 flex items-center justify-center rounded-xl hover:bg-white hover:border hover:border-[#e2e8f0] transition-all">
          3
        </a>

        <a href="#" class="w-10 h-10 flex items-center justify-center rounded-xl border border-[#e2e8f0] bg-white hover:border-[#cbd5e1] transition-all">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>

    </section>
  </main>

  <Footer />
</Layout>