---
import Layout from "../layouts/Layout.astro";
import Footer from "../components/organisms/Footer.astro";
import ArchivesSection from "../components/organisms/Archives/ArchivesSection.astro";
---

<Layout>
  <main class="min-h-screen pt-40 pb-20 md:pb-32 px-6">
    <div class="max-w-6xl mx-auto w-full">
      <div class="max-w-4xl">
        <h1
          class="text-6xl md:text-8xl lg:text-[110px] text-[#1e293b] mb-8 tracking-tight leading-[1.1] italic transition-all"
          style="font-family: 'Playfair Display', serif;"
        >
          Selected Archives
        </h1>

        <p
          class="text-slate-500 text-[17px] md:text-[19px] leading-[1.7] font-light mb-16 md:mb-24 max-w-[650px]"
        >
          Exploring the silent intersection where digital whispers meet physical
          resonance.<br class="hidden sm:block" />
          A curated collection of spatial inquiries and ethereal structures.
        </p>

        <div class="w-full">
          <div
            class="flex items-center gap-8 md:gap-12 overflow-x-auto pb-4 border-b border-[#e2e8f0]"
          >
            <a
              href="#"
              class="block text-xs font-bold tracking-[0.2em] text-[#3cbce6] uppercase whitespace-nowrap"
            >
              All Projects
            </a>
            <a
              href="#"
              class="block text-xs font-medium tracking-[0.2em] text-slate-400 hover:text-slate-600 uppercase transition-colors whitespace-nowrap"
            >
              Digital
            </a>
            <a
              href="#"
              class="block text-xs font-medium tracking-[0.2em] text-slate-400 hover:text-slate-600 uppercase transition-colors whitespace-nowrap"
            >
              Spatial
            </a>
            <a
              href="#"
              class="block text-xs font-medium tracking-[0.2em] text-slate-400 hover:text-slate-600 uppercase transition-colors whitespace-nowrap"
            >
              Conceptual
            </a>
          </div>
        </div>
      </div>
    </div>
    <ArchivesSection />
  </main>

  <Footer />
</Layout>
