---
import StoryStage from "../../molecules/StoryStage.astro";
---

<StoryStage id="stageStory8" mantra="ꦮꦫꦶꦱꦤ꧀ꦲꦧꦢꦶ" stageLabel="X. Warisan Abadi">
  <svg slot="illustration" viewBox="0 0 200 120" class="w-36 h-24 md:w-48 md:h-32 mb-6 shrink-0">
    <line x1="0" y1="90" x2="200" y2="90" stroke="#C5A059" stroke-width="0.8" opacity="0.4" />
    <clipPath id="horizonClip"><rect x="0" y="0" width="200" height="90" /></clipPath>
    <circle cx="100" cy="90" r="38" fill="none" stroke="#C5A059" stroke-width="1.5" opacity="0.6" clip-path="url(#horizonClip)" />
    <circle cx="100" cy="90" r="12" fill="#C5A059" opacity="0.15" clip-path="url(#horizonClip)" />
    <path d="M 100 85 Q 105 70 100 55 Q 95 40 100 25" fill="none" stroke="#C5A059" stroke-width="1" stroke-dasharray="2 4" opacity="0.6" />
    <circle cx="100" cy="22" r="2" fill="#C5A059" opacity="0.7" />
  </svg>
  <p class="text-[#F8F5F0] font-serif italic text-base sm:text-xl md:text-2xl leading-relaxed tracking-wide font-light max-w-xl">
    "The world forgets the winner. It never forgets Karna."
  </p>
  <div class="mt-4 sm:mt-6 border border-[#C5A059]/20 px-5 sm:px-6 py-3 sm:py-4 max-w-md">
    <p class="text-[#F8F5F0] font-serif italic text-xs sm:text-sm leading-relaxed opacity-70">
      "The bravest thing you will ever do is remain yourself — when the world has given you every reason not to."
    </p>
  </div>
</StoryStage>
