---
import StoryStage from "../../molecules/StoryStage.astro";
---

<StoryStage id="stageStory1" mantra="ꦏꦫ꧀ꦤ" stageLabel="III. Kelahiran yang Dibuang">
  <svg slot="illustration" viewBox="0 0 200 200" class="w-28 h-28 md:w-40 md:h-40 mb-6 shrink-0 opacity-40">
    <circle cx="100" cy="100" r="80" fill="none" stroke="#C5A059" stroke-width="0.5" stroke-dasharray="4 8" />
    <g transform="translate(100,100)">
      <line x1="0" y1="-70" x2="0" y2="-55" stroke="#C5A059" stroke-width="1.5" />
      <line x1="0" y1="-70" x2="0" y2="-55" stroke="#C5A059" stroke-width="1.5" transform="rotate(60)" />
      <line x1="0" y1="-70" x2="0" y2="-55" stroke="#C5A059" stroke-width="1.5" transform="rotate(120)" />
      <line x1="0" y1="-70" x2="0" y2="-55" stroke="#C5A059" stroke-width="1.5" transform="rotate(180)" />
      <line x1="0" y1="-70" x2="0" y2="-55" stroke="#C5A059" stroke-width="1.5" transform="rotate(240)" />
      <line x1="0" y1="-70" x2="0" y2="-55" stroke="#C5A059" stroke-width="1.5" transform="rotate(300)" />
      <circle r="25" fill="none" stroke="#C5A059" stroke-width="1" />
      <circle r="3" fill="#C5A059" />
    </g>
  </svg>
  <p class="text-[#F8F5F0] font-serif italic text-base sm:text-xl md:text-2xl leading-relaxed tracking-wide font-light max-w-xl">
    "Born armored in gold — placed on the river's mercy by the mother who could not keep him."
  </p>
</StoryStage>
