---
import MantraCircle from "../../atoms/MantraCircle.astro";
---

<div
  id="stageFoundation"
  class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none opacity-0 will-change-transform"
>
  <div class="relative w-40 h-40 md:w-64 md:h-64 flex items-center justify-center mb-10">
    <div class="absolute inset-0 flex items-center justify-center animate-[spin_30s_linear_infinite_reverse] z-10 pointer-events-none">
      <MantraCircle
        pathId="mantraCircle"
        text="ꦲꦤꦕꦫꦏ ꦢꦠꦱꦮꦭ ꦥꦣꦗꦪꦚ ꦩꦒꦧꦛꦔ ꦲꦤꦕꦫꦏ ꦢꦠꦱꦮꦭ ꦥꦣꦗꦪ"
        radius={75}
        fontSize="text-[13px] md:text-[14px]"
        svgClass="absolute w-[160%] h-[160%] md:w-[150%] md:h-[150%] opacity-60 drop-shadow-[0_0_10px_rgba(197,160,89,0.4)]"
      />
    </div>
    <div class="absolute w-32 h-32 md:w-48 md:h-48 border border-[#C5A059]/30 rotate-45 transform origin-center animate-[spin_20s_linear_infinite]"></div>
    <div class="absolute w-24 h-24 md:w-36 md:h-36 border border-[#C5A059]/50 rounded-full animate-[spin_15s_linear_infinite_reverse] border-dashed"></div>
    <div class="w-2 h-2 bg-[#C5A059] rounded-full shadow-[0_0_15px_rgba(197,160,89,1)]"></div>
  </div>
  <h2 class="text-4xl md:text-5xl text-[#C5A059] font-serif mb-6 drop-shadow-[0_0_15px_rgba(197,160,89,0.5)] z-20">ꦲꦤꦕꦫꦏ</h2>
  <p class="text-[#A39E93] tracking-[0.6em] text-[9px] md:text-[11px] uppercase font-light z-20">I. The Foundation</p>
</div>
