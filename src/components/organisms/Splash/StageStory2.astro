---
import StoryStage from "../../molecules/StoryStage.astro";
---

<StoryStage id="stageStory2" mantra="ꦱꦸꦠꦥꦸꦠꦿ" stageLabel="IV. Sang Suta Putra">
  <svg slot="illustration" viewBox="0 0 80 160" class="w-20 h-32 md:w-28 md:h-44 mb-6 shrink-0 opacity-60 drop-shadow-[0_0_12px_rgba(197,160,89,0.4)]">
    <path d="M 60 10 Q 10 80 60 150" fill="none" stroke="#C5A059" stroke-width="2" stroke-linecap="round" />
    <line x1="15" y1="80" x2="72" y2="80" stroke="#C5A059" stroke-width="1.5" stroke-linecap="round" />
    <polygon points="72,80 65,76 65,84" fill="#C5A059" />
  </svg>
  <p class="text-[#F8F5F0] font-serif italic text-base sm:text-xl md:text-2xl leading-relaxed tracking-wide font-light max-w-xl">
    "They did not ask of his skill. They asked of his father's name."
  </p>
  <p class="text-[#A39E93] text-xs sm:text-sm font-serif italic mt-3 max-w-md opacity-60">
    <span class="text-[#C5A059]/70">And laughed.</span>
  </p>
</StoryStage>
