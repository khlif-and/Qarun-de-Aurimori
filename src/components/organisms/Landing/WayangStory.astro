---
// src/components/organisms/Landing/WayangStory.astro
---
<!-- Stage: Story 1 -->
<div id="stageStory1" class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none opacity-0 px-6 text-center will-change-transform">
  <svg viewBox="0 0 100 150" class="w-8 h-12 mb-6 opacity-60 drop-shadow-[0_0_10px_rgba(197,160,89,0.3)]"><path d="M50 0 C70 50, 100 90, 100 150 L0 150 C0 90, 30 50, 50 0 Z" fill="none" stroke="#C5A059" stroke-width="2"/></svg>
  <p class="text-[#F8F5F0] font-serif italic text-xl md:text-3xl leading-relaxed tracking-wide font-light max-w-2xl">
    "A vow forged in gold and shadow.<br/>Loyalty over blood."
  </p>
  <p class="text-[#A39E93] tracking-[0.6em] text-[9px] md:text-[11px] uppercase mt-12 font-light">III. The Vow</p>
</div>

<!-- Stage: Story 2 -->
<div id="stageStory2" class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none opacity-0 px-6 text-center will-change-transform">
  <div class="relative w-32 h-32 md:w-40 md:h-40 flex items-center justify-center mb-10">
    <div class="absolute w-24 h-24 border border-[#C5A059]/40 rotate-45 animate-[spin_10s_linear_infinite]"></div>
    <div class="absolute w-16 h-16 border border-[#C5A059]/60 rounded-full border-dashed animate-[spin_15s_linear_infinite_reverse]"></div>
  </div>
  <p class="text-[#F8F5F0] font-serif italic text-xl md:text-3xl leading-relaxed tracking-wide font-light max-w-3xl">
    "The conch shells weep.<br/>Brothers face brothers upon the crimson earth."
  </p>
  <p class="text-[#A39E93] tracking-[0.6em] text-[9px] md:text-[11px] uppercase mt-12 font-light">IV. Kurukshetra</p>
</div>

<!-- Stage: Story 3 -->
<div id="stageStory3" class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none opacity-0 px-6 text-center will-change-transform">
  <div class="w-[1px] h-32 bg-gradient-to-b from-[#C5A059]/80 to-transparent mb-10 shadow-[0_0_15px_rgba(197,160,89,0.8)]"></div>
  <p class="text-[#F8F5F0] font-serif italic text-2xl md:text-4xl leading-relaxed tracking-wide font-light max-w-2xl">
    "A silent arrow.<br/>A brilliant twilight."
  </p>
  <p class="text-[#A39E93] tracking-[0.6em] text-[9px] md:text-[11px] uppercase mt-12 font-light">V. The Fall</p>
</div>

<!-- Stage: Story 4 -->
<div id="stageStory4" class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none opacity-0 px-6 text-center will-change-transform">
  <p class="text-[#F8F5F0] font-serif italic text-xl md:text-3xl leading-relaxed tracking-wide font-light max-w-2xl mb-6">
    "...and the highest sun finally sets."
  </p>
  <svg viewBox="0 0 100 150" class="w-8 h-12 mt-6 opacity-60 rotate-180 drop-shadow-[0_0_10px_rgba(197,160,89,0.3)]"><path d="M50 0 C70 50, 100 90, 100 150 L0 150 C0 90, 30 50, 50 0 Z" fill="none" stroke="#C5A059" stroke-width="2"/></svg>
  <p class="text-[#A39E93] tracking-[0.6em] text-[10px] md:text-[12px] uppercase mt-12 font-light">VI. The Epilogue</p>
</div>
