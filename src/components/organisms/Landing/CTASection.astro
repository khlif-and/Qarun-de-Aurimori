<section class="w-full bg-[#fbfcfd] py-32 md:py-48 flex justify-center px-6 relative overflow-hidden" id="contact">
  <!-- Subtle Glow Background -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-sky-50 rounded-full blur-[120px] opacity-70"></div>

  <div class="relative z-10 max-w-[800px] w-full flex flex-col items-center text-center gap-8 md:gap-10">
    <h2 class="text-5xl md:text-[70px] text-[#1e293b] font-serif tracking-tight" style="font-family: 'Playfair Display', serif;">
      Begin the Journey
    </h2>
    <p class="text-slate-500 text-lg md:text-[21px] font-light mb-4">
      Let us build something that transcends the screen.
    </p>
    
    <div class="flex flex-col sm:flex-row gap-5 w-full sm:w-auto mt-2">
      <a href="#contact" class="flex-1 sm:flex-none px-9 py-4 bg-[#3cbce6] hover:bg-[#2ab0dd] text-white font-bold rounded-[12px] shadow-lg shadow-sky-200/50 transition-all duration-300">
        Contact Us
      </a>
      <a href="#portfolio" class="flex-1 sm:flex-none px-9 py-4 bg-white border-[1.5px] border-slate-200 hover:border-slate-300 text-[#1e293b] font-bold rounded-[12px] shadow-sm transition-all duration-300">
        Download Portfolio
      </a>
    </div>
  </div>
</section>
