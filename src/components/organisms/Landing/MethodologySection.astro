<style>
  @keyframes holoSpin {
    0% { transform: rotateY(0deg) rotateX(5deg) translateY(0px); }
    50% { transform: rotateY(180deg) rotateX(-5deg) translateY(-20px); }
    100% { transform: rotateY(360deg) rotateX(5deg) translateY(0px); }
  }
  @keyframes holoSpinReverse {
    0% { transform: rotateY(360deg) rotateX(5deg) translateY(0px); }
    50% { transform: rotateY(180deg) rotateX(-5deg) translateY(-20px); }
    100% { transform: rotateY(0deg) rotateX(5deg) translateY(0px); }
  }
  .hologram-3d {
    transform-style: preserve-3d;
  }
</style>

<section class="relative w-full bg-[#0a0a0a] py-32 md:py-48 flex justify-center px-6 overflow-hidden" id="methodology">
  
  <!-- Mystical Background Texture (Overlay) -->
  <div class="absolute inset-0 z-0 pointer-events-none opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E');"></div>
  
  <!-- Giant faint Javanese character -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-0 pointer-events-none opacity-[0.03]">
    <span class="text-[400px] md:text-[600px] text-[#C5A059] font-serif leading-none tracking-tighter">ꦩꦒ</span>
  </div>

  <!-- 3D Holographic Wayang (Left - Arjuna Type) -->
  <div class="absolute left-[-30%] md:left-[-15%] top-1/2 -translate-y-1/2 pointer-events-none z-0" style="perspective: 1000px;">
    <div class="hologram-3d relative w-[350px] h-[700px] md:w-[600px] md:h-[1200px] animate-[holoSpin_35s_linear_infinite]">
      { [0, 15, 30].map(z => (
        <div class="absolute inset-0 opacity-25" style={`transform: translateZ(${z}px);`}>
          <!-- KANON SVG (Background) -->
          <svg viewBox="0 0 100 200" class="absolute inset-0 w-full h-full drop-shadow-[0_0_15px_rgba(197,160,89,0.5)] mix-blend-screen scale-[1.0] opacity-30">
            <path d="M50 10 C75 50, 95 100, 95 150 C95 180, 75 190, 50 190 C25 190, 5 180, 5 150 C5 100, 25 50, 50 10 Z" fill="none" stroke="#C5A059" stroke-width="0.5"/>
            <path d="M50 25 C65 60, 80 100, 80 145 C80 170, 65 180, 50 180 C35 180, 20 170, 20 145 C20 100, 35 60, 50 25 Z" fill="none" stroke="#C5A059" stroke-width="0.5" stroke-dasharray="2 2"/>
            <circle cx="50" cy="140" r="25" fill="none" stroke="#C5A059" stroke-width="0.5"/>
            <line x1="50" y1="190" x2="50" y2="10" stroke="#C5A059" stroke-width="0.5"/>
            <circle cx="30" cy="160" r="4" fill="none" stroke="#C5A059" stroke-width="0.5"/>
            <circle cx="70" cy="160" r="4" fill="none" stroke="#C5A059" stroke-width="0.5"/>
            <circle cx="50" cy="100" r="6" fill="none" stroke="#C5A059" stroke-width="0.5"/>
          </svg>
          <!-- ARJUNA SVG -->
          <svg viewBox="0 0 600 1000" class="absolute inset-0 w-full h-full drop-shadow-[0_0_15px_rgba(197,160,89,0.8)] mix-blend-screen scale-[0.6] mt-4">
            <path d="M250 150 C300 50, 450 30, 480 150 C550 300, 400 350, 300 300 C280 290, 260 250, 250 150 Z" fill="none" stroke="#C5A059" stroke-width="2"/>
            <path d="M480 150 C500 180, 520 280, 450 330" fill="none" stroke="#C5A059" stroke-width="2" stroke-dasharray="4 4"/>
            <circle cx="350" cy="220" r="10" fill="none" stroke="#C5A059" stroke-width="2"/>
            <path d="M250 150 C220 160, 180 200, 150 250 C130 290, 100 310, 80 330 C120 330, 150 290, 170 270 C190 290, 210 320, 240 300" fill="none" stroke="#C5A059" stroke-width="3"/>
            <path d="M200 230 C220 220, 240 230, 230 240 C210 245, 190 235, 200 230 Z" fill="none" stroke="#C5A059" stroke-width="1.5"/>
            <path d="M210 235 Q220 235, 225 240" fill="none" stroke="#C5A059" stroke-width="2"/>
            <path d="M240 300 C280 380, 320 500, 300 650" fill="none" stroke="#C5A059" stroke-width="2"/>
            <path d="M350 300 C380 400, 420 520, 380 660" fill="none" stroke="#C5A059" stroke-width="2"/>
            <path d="M280 350 Q360 400, 350 320" fill="none" stroke="#C5A059" stroke-width="1.5" stroke-dasharray="2 2"/>
            <path d="M280 400 L150 600 L120 520 L80 500L90 470" fill="none" stroke="#C5A059" stroke-width="2.5"/>
            <circle cx="150" cy="600" r="8" fill="none" stroke="#C5A059" stroke-width="2"/>
            <circle cx="120" cy="520" r="6" fill="none" stroke="#C5A059" stroke-width="2"/>
            <path d="M150 600 L160 850" fill="none" stroke="#C5A059" stroke-width="1"/>
            <path d="M370 380 L480 580 L420 750 L450 820" fill="none" stroke="#C5A059" stroke-width="2.5"/>
            <circle cx="480" cy="580" r="8" fill="none" stroke="#C5A059" stroke-width="2"/>
            <circle cx="420" cy="750" r="6" fill="none" stroke="#C5A059" stroke-width="2"/>
            <path d="M420 750 L400 950" fill="none" stroke="#C5A059" stroke-width="1"/>
            <path d="M300 650 C220 750, 180 880, 250 1050" fill="none" stroke="#C5A059" stroke-width="2"/>
            <path d="M380 660 C480 800, 520 900, 400 1050" fill="none" stroke="#C5A059" stroke-width="2"/>
            <path d="M250 1050 L400 1050" fill="none" stroke="#C5A059" stroke-width="2"/>
            <path d="M300 650 L320 1200" fill="none" stroke="#C5A059" stroke-width="3"/>
            <path d="M280 720 Q350 850, 450 780" fill="none" stroke="#C5A059" stroke-width="1.5" stroke-dasharray="8 8"/>
            <path d="M260 820 Q350 950, 440 880" fill="none" stroke="#C5A059" stroke-width="1.5" stroke-dasharray="5 5"/>
            <path d="M280 920 Q350 1000, 410 950" fill="none" stroke="#C5A059" stroke-width="1.5" stroke-dasharray="3 3"/>
          </svg>
        </div>
      )) }
    </div>
  </div>

  <!-- 3D Holographic Wayang (Right - Bima Type) -->
  <div class="absolute right-[-30%] md:right-[-15%] top-1/2 -translate-y-1/2 pointer-events-none z-0" style="perspective: 1000px;">
    <div class="hologram-3d relative w-[350px] h-[700px] md:w-[600px] md:h-[1200px] animate-[holoSpinReverse_35s_linear_infinite] scale-x-[-1]">
      { [0, 15, 30].map(z => (
        <div class="absolute inset-0 opacity-25" style={`transform: translateZ(${z}px);`}>
           <!-- KANON SVG (Background) -->
           <svg viewBox="0 0 100 200" class="absolute inset-0 w-full h-full drop-shadow-[0_0_15px_rgba(197,160,89,0.5)] mix-blend-screen scale-[1.0] opacity-30">
            <path d="M50 10 C75 50, 95 100, 95 150 C95 180, 75 190, 50 190 C25 190, 5 180, 5 150 C5 100, 25 50, 50 10 Z" fill="none" stroke="#C5A059" stroke-width="0.5"/>
            <path d="M50 25 C65 60, 80 100, 80 145 C80 170, 65 180, 50 180 C35 180, 20 170, 20 145 C20 100, 35 60, 50 25 Z" fill="none" stroke="#C5A059" stroke-width="0.5" stroke-dasharray="2 2"/>
            <circle cx="50" cy="140" r="25" fill="none" stroke="#C5A059" stroke-width="0.5"/>
            <line x1="50" y1="190" x2="50" y2="10" stroke="#C5A059" stroke-width="0.5"/>
            <circle cx="30" cy="160" r="4" fill="none" stroke="#C5A059" stroke-width="0.5"/>
            <circle cx="70" cy="160" r="4" fill="none" stroke="#C5A059" stroke-width="0.5"/>
            <circle cx="50" cy="100" r="6" fill="none" stroke="#C5A059" stroke-width="0.5"/>
          </svg>
           <!-- BIMA SVG -->
           <svg viewBox="0 0 600 1000" class="absolute inset-0 w-full h-full drop-shadow-[0_0_15px_rgba(197,160,89,0.8)] mix-blend-screen scale-[0.6] mt-4">
            <path d="M250 180 C280 100, 380 80, 450 150 C480 250, 350 300, 300 280 C270 260, 260 220, 250 180 Z" fill="none" stroke="#C5A059" stroke-width="2.5"/>
            <circle cx="350" cy="200" r="15" fill="none" stroke="#C5A059" stroke-width="2"/>
            <path d="M250 180 C200 190, 150 230, 140 280 C110 300, 80 310, 60 310 C100 330, 140 310, 160 290 C180 320, 210 340, 240 310" fill="none" stroke="#C5A059" stroke-width="3"/>
            <path d="M180 240 C210 230, 230 250, 220 270 C190 280, 170 260, 180 240 Z" fill="none" stroke="#C5A059" stroke-width="2"/>
            <path d="M240 310 C300 450, 320 600, 280 750" fill="none" stroke="#C5A059" stroke-width="3"/>
            <path d="M350 310 C400 480, 450 630, 400 780" fill="none" stroke="#C5A059" stroke-width="3"/>
            <path d="M280 450 L100 700 L80 620 L30 650 L20 600" fill="none" stroke="#C5A059" stroke-width="3"/>
            <circle cx="100" cy="700" r="12" fill="none" stroke="#C5A059" stroke-width="2"/>
            <circle cx="80" cy="620" r="8" fill="none" stroke="#C5A059" stroke-width="2"/>
            <path d="M100 700 L110 950" fill="none" stroke="#C5A059" stroke-width="1.5"/>
            <path d="M30 650 C10 680, 0 720, 20 750" fill="none" stroke="#C5A059" stroke-width="2"/> 
            <path d="M380 420 L550 680 L480 850 L520 950" fill="none" stroke="#C5A059" stroke-width="3"/>
            <circle cx="550" cy="680" r="12" fill="none" stroke="#C5A059" stroke-width="2"/>
            <circle cx="480" cy="850" r="8" fill="none" stroke="#C5A059" stroke-width="2"/>
            <path d="M480 850 L460 1100" fill="none" stroke="#C5A059" stroke-width="1.5"/>
            <path d="M340 700 L340 1200" fill="none" stroke="#C5A059" stroke-width="4"/>
            <path d="M280 750 C200 880, 150 1050, 250 1200" fill="none" stroke="#C5A059" stroke-width="3"/>
            <path d="M400 780 C500 950, 550 1080, 450 1200" fill="none" stroke="#C5A059" stroke-width="3"/>
            <path d="M250 1200 L450 1200" fill="none" stroke="#C5A059" stroke-width="3"/>
            <path d="M290 850 L420 880 M270 950 L460 980 M250 1050 L440 1080 M260 1150 L430 1180" fill="none" stroke="#C5A059" stroke-width="2" stroke-dasharray="14 14"/>
          </svg>
        </div>
      )) }
    </div>
  </div>

  <div class="relative max-w-[760px] w-full flex flex-col gap-14 md:gap-20 z-10">
    
    <!-- Section Heading -->
    <div class="flex flex-col items-center text-center gap-6">
      <span class="text-[#C5A059] text-[12px] md:text-sm font-light tracking-[0.8em] uppercase drop-shadow-[0_0_5px_rgba(197,160,89,1)]">
        Methodology of The Ancients
      </span>
      
      <h2 class="text-4xl md:text-5xl text-[#C5A059] tracking-wider font-serif italic drop-shadow-[0_0_15px_rgba(197,160,89,0.3)] mt-2" style="font-family: 'Playfair Display', serif;">
        How the Gold is Made
      </h2>
      <div class="w-[1px] h-24 bg-gradient-to-b from-[#C5A059]/60 to-transparent mt-4"></div>
    </div>

    <!-- Body Text (Mapped from original methodology steps to single column, stacked) -->
    <div class="text-[#A39E93] text-[16px] md:text-[18px] leading-[2.2] flex flex-col gap-16 font-serif font-light text-center px-4" style="font-family: 'Lora', serif;">
      
      <!-- Step 1 -->
      <div class="flex flex-col items-center gap-4">
        <span class="text-[#C5A059] font-serif italic text-4xl drop-shadow-[0_0_15px_rgba(197,160,89,0.8)] opacity-60">ꦱꦶꦗꦶ</span>
        <h3 class="text-[26px] text-[#F8F5F0] font-serif tracking-widest drop-shadow-[0_0_10px_rgba(0,0,0,1)]" style="font-family: 'Playfair Display', serif;">I. Descent</h3>
        <p class="text-[#A39E93] max-w-[600px] mx-auto">
          Before anything is made, something must be entered. We go down —
          into the question, into the discomfort, into the part of the brief
          that no one wanted to say out loud. That is where the work begins.
        </p>
      </div>

      <div class="w-full flex justify-center opacity-30">
        <div class="w-1 h-1 bg-[#C5A059] rounded-full mx-2"></div>
        <div class="w-1 h-1 bg-[#C5A059] rounded-full mx-2"></div>
        <div class="w-1 h-1 bg-[#C5A059] rounded-full mx-2"></div>
      </div>

      <!-- Step 2 -->
      <div class="flex flex-col items-center gap-4">
        <span class="text-[#C5A059] font-serif italic text-4xl drop-shadow-[0_0_15px_rgba(197,160,89,0.8)] opacity-60">ꦭꦺꦴꦫꦺꦴ</span>
        <h3 class="text-[26px] text-[#F8F5F0] font-serif tracking-widest drop-shadow-[0_0_10px_rgba(0,0,0,1)]" style="font-family: 'Playfair Display', serif;">II. Pressure</h3>
        <p class="text-[#A39E93] max-w-[600px] mx-auto">
          Gold is not found — it is made. By heat, by weight, by the slow
          violence of everything unnecessary being forced out. We sit inside
          that pressure until only what is true remains.
        </p>
      </div>

      <div class="w-full flex justify-center opacity-30">
        <div class="w-1 h-1 bg-[#C5A059] rounded-full mx-2"></div>
        <div class="w-1 h-1 bg-[#C5A059] rounded-full mx-2"></div>
        <div class="w-1 h-1 bg-[#C5A059] rounded-full mx-2"></div>
      </div>

      <!-- Step 3 -->
      <div class="flex flex-col items-center gap-4">
        <span class="text-[#C5A059] font-serif italic text-4xl drop-shadow-[0_0_15px_rgba(197,160,89,0.8)] opacity-60">ꦠꦼꦭꦸ</span>
        <h3 class="text-[26px] text-[#F8F5F0] font-serif tracking-widest drop-shadow-[0_0_10px_rgba(0,0,0,1)]" style="font-family: 'Playfair Display', serif;">III. Emergence</h3>
        <p class="text-[#A39E93] max-w-[600px] mx-auto">
          What surfaces is never what we planned. It is what survived
          the process — quieter than expected, heavier than it looks,
          and somehow already familiar.
        </p>
      </div>

    </div>
  </div>
</section>