---
// src/components/organisms/Splash.astro
import splashAudio from "../../assets/audio/opening.mp3";
---

<div id="splash" class="fixed inset-0 z-[100] bg-transparent overflow-hidden">
  <audio id="splashMusic" src={splashAudio} preload="auto" loop></audio>

  <!-- Outer Gates (Cover) -->
  <div id="gatesContainer" class="absolute inset-0 z-50 pointer-events-none">
    <!-- Left Gate -->
    <div
      id="gateLeft"
      class="absolute left-0 top-0 w-1/2 h-full bg-[#0a0a0a] border-r-[2px] border-[#C5A059]/50 flex items-center justify-end overflow-hidden will-change-transform shadow-[15px_0_50px_rgba(0,0,0,0.95)]"
    >
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n1%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.7%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n1)%22/%3E%3C/svg%3E');"
      >
      </div>
      <div
        class="absolute inset-4 md:inset-8 border border-[#C5A059]/20 border-r-0"
      >
      </div>
      <div
        class="absolute right-0 translate-x-1/2 flex items-center justify-center opacity-20"
      >
        <div class="w-72 h-72 border border-[#C5A059] rounded-full"></div>
      </div>
      <!-- Left Gate Vertical Mantra -->
      <div
        class="absolute right-8 md:right-16 top-1/2 -translate-y-1/2 flex flex-col items-center opacity-40"
      >
        <span
          class="text-[#C5A059] text-lg md:text-2xl font-serif tracking-[0.5em]"
          style="writing-mode: vertical-rl; text-orientation: upright;"
          >ꦲꦤꦕꦫꦏꦢꦠꦱꦮꦭ</span
        >
      </div>
    </div>

    <!-- Right Gate -->
    <div
      id="gateRight"
      class="absolute right-0 top-0 w-1/2 h-full bg-[#0a0a0a] border-l-[2px] border-[#C5A059]/50 flex items-center justify-start overflow-hidden will-change-transform shadow-[-15px_0_50px_rgba(0,0,0,0.95)]"
    >
      <div
        class="absolute inset-0 opacity-[0.04]"
        style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n2%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.7%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n2)%22/%3E%3C/svg%3E');"
      >
      </div>
      <div
        class="absolute inset-4 md:inset-8 border border-[#C5A059]/20 border-l-0"
      >
      </div>
      <div
        class="absolute left-0 -translate-x-1/2 flex items-center justify-center opacity-20"
      >
        <div class="w-72 h-72 border border-[#C5A059] rounded-full"></div>
      </div>
      <!-- Right Gate Vertical Mantra -->
      <div
        class="absolute left-8 md:left-16 top-1/2 -translate-y-1/2 flex flex-col items-center opacity-40"
      >
        <span
          class="text-[#C5A059] text-lg md:text-2xl font-serif tracking-[0.5em]"
          style="writing-mode: vertical-rl; text-orientation: upright;"
          >ꦥꦣꦗꦪꦚꦩꦒꦧꦛꦔ</span
        >
      </div>
    </div>

    <!-- Gate Center Emblem -->
    <div
      id="gateEmblem"
      class="absolute inset-0 flex flex-col items-center justify-center transition-opacity duration-300"
    >
      <!-- Mystical Emblem Mantra Background -->
      <div
        class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-30 mix-blend-screen z-0 animate-[spin_60s_linear_infinite]"
      >
        <svg
          viewBox="0 0 400 400"
          class="w-[150%] h-[150%] md:w-[80vw] md:h-[80vw] max-w-[800px] max-h-[800px] drop-shadow-[0_0_15px_rgba(197,160,89,0.4)]"
        >
          <path
            id="emblemMantra"
            d="M 200, 50 a 150,150 0 1,1 0,300 a 150,150 0 1,1 0,-300"
            fill="none"></path>
          <text>
            <textPath
              href="#emblemMantra"
              startOffset="0%"
              class="text-[11px] md:text-[12px] fill-[#C5A059] font-serif tracking-[0.5em]"
            >
              ꦏꦼꦱꦸꦚꦶꦪꦤ꧀ ꦲꦶꦁ ꦱꦼꦧꦭꦶꦏ꧀ ꦕꦲꦪ ꦢꦤ꧀ ꦧꦪꦔꦤ꧀ ꦏꦼꦱꦸꦚꦶꦪꦤ꧀ ꦲꦶꦁ ꦱꦼꦧꦭꦶꦏ꧀ ꦕꦲꦪ ꦢꦤ꧀
              ꦧꦪꦔꦤ꧀
            </textPath>
          </text>
        </svg>
      </div>

      <span
        class="text-[#C5A059] tracking-[0.4em] text-[10px] md:text-xs uppercase mb-6 font-light opacity-80 z-50"
        >Maison</span
      >
      <h1
        class="text-[50px] md:text-[80px] lg:text-[110px] text-[#F8F5F0] font-serif tracking-normal leading-none z-50"
        style="font-family: 'Playfair Display', serif;"
      >
        Qarun
      </h1>
      <p
        class="text-[#A39E93] tracking-[0.2em] text-sm md:text-base font-serif italic z-50 mt-8"
      >
        de Aurimori
      </p>
    </div>
  </div>

  <!-- Inner Journal Area (Z-40) -->
  <div
    id="innerJournal"
    class="absolute inset-0 z-40 bg-[#0c0c0c] flex flex-col items-center justify-center will-change-transform opacity-100"
  >
    <div
      class="absolute inset-0 opacity-[0.05] pointer-events-none"
      style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n3%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.8%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n3)%22/%3E%3C/svg%3E');"
    >
    </div>

    <!-- Elegant Book Frame inside Journal -->
    <div
      class="absolute inset-6 md:inset-12 border border-[#C5A059]/10 pointer-events-none"
    >
      <div
        class="absolute top-0 left-1/2 -translate-x-1/2 w-[1px] h-full bg-[#C5A059]/5"
      >
      </div>
    </div>

    <!-- Stage: Foundation -->
    <div
      id="stageFoundation"
      class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none opacity-0 will-change-transform"
    >
      <div
        class="relative w-40 h-40 md:w-64 md:h-64 flex items-center justify-center mb-10"
      >
        <!-- Rotating Mantra -->
        <div
          class="absolute inset-0 flex items-center justify-center animate-[spin_30s_linear_infinite_reverse] z-10 pointer-events-none"
        >
          <svg
            viewBox="0 0 200 200"
            class="absolute w-[160%] h-[160%] md:w-[150%] md:h-[150%] opacity-60 drop-shadow-[0_0_10px_rgba(197,160,89,0.4)]"
          >
            <path
              id="mantraCircle"
              d="M 100, 25 a 75,75 0 1,1 0,150 a 75,75 0 1,1 0,-150"
              fill="none"></path>
            <text>
              <textPath
                href="#mantraCircle"
                startOffset="0%"
                class="text-[13px] md:text-[14px] fill-[#C5A059] font-serif tracking-[0.25em]"
              >
                ꦲꦤꦕꦫꦏ ꦢꦠꦱꦮꦭ ꦥꦣꦗꦪꦚ ꦩꦒꦧꦛꦔ ꦲꦤꦕꦫꦏ ꦢꦠꦱꦮꦭ ꦥꦣꦗꦪ
              </textPath>
            </text>
          </svg>
        </div>

        <div
          class="absolute w-32 h-32 md:w-48 md:h-48 border border-[#C5A059]/30 rotate-45 transform origin-center animate-[spin_20s_linear_infinite]"
        >
        </div>
        <div
          class="absolute w-24 h-24 md:w-36 md:h-36 border border-[#C5A059]/50 rounded-full animate-[spin_15s_linear_infinite_reverse] border-dashed"
        >
        </div>
        <div
          class="w-2 h-2 bg-[#C5A059] rounded-full shadow-[0_0_15px_rgba(197,160,89,1)]"
        >
        </div>
      </div>
      <h2
        class="text-4xl md:text-5xl text-[#C5A059] font-serif mb-6 drop-shadow-[0_0_15px_rgba(197,160,89,0.5)] z-20"
      >
        ꦲꦤꦕꦫꦏ
      </h2>
      <p
        class="text-[#A39E93] tracking-[0.6em] text-[9px] md:text-[11px] uppercase font-light z-20"
      >
        I. The Foundation
      </p>
    </div>

    <!-- Stage: Vision -->
    <div
      id="stageVision"
      class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none opacity-0 px-6 text-center will-change-transform"
    >
      <div class="relative w-full h-48 md:h-64 flex justify-center mb-10">
        <div
          class="absolute w-40 h-40 md:w-56 md:h-56 rounded-full bg-[#C5A059] opacity-[0.08] blur-2xl top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2"
        >
        </div>
        <!-- Needle -->
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1px] h-56 md:h-72 bg-gradient-to-b from-transparent via-[#C5A059]/60 to-transparent z-0"
        >
        </div>
        <!-- Astrolabe / Lens UI -->
        <div
          class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 md:w-64 md:h-64 flex items-center justify-center pointer-events-none"
        >
          <div
            class="absolute w-full h-full border-[1px] border-[#C5A059]/20 rounded-full border-dashed animate-[spin_40s_linear_infinite]"
          >
          </div>
          <div
            class="absolute w-[80%] h-[80%] border-[1px] border-[#C5A059]/30 rounded-full animate-[spin_25s_linear_infinite_reverse]"
          >
          </div>
          <div
            class="absolute w-[60%] h-[60%] border-[1px] border-[#C5A059]/10 rounded-full"
          >
          </div>
          <div
            class="absolute w-12 h-12 md:w-16 md:h-16 border-[1px] border-[#C5A059]/60 rotate-45 z-10 drop-shadow-[0_0_10px_rgba(197,160,89,0.5)]"
          >
          </div>
          <div
            class="absolute w-2 h-2 bg-[#F8F5F0] rounded-full animate-pulse blur-[1px] drop-shadow-[0_0_5px_rgba(248,245,240,1)]"
          >
          </div>
          <div
            class="absolute w-[120%] h-[1px] bg-gradient-to-r from-transparent via-[#C5A059]/30 to-transparent"
          >
          </div>
        </div>
      </div>
      <h2
        class="text-4xl md:text-5xl text-[#C5A059] font-serif mb-6 drop-shadow-[0_0_15px_rgba(197,160,89,0.5)] z-20"
      >
        ꦱꦸꦫꦢꦶꦫ
      </h2>
      <p
        class="text-[#F8F5F0] font-serif italic text-2xl md:text-3xl lg:text-4xl leading-relaxed tracking-wide font-light max-w-3xl z-20"
      >
        "In the orchestration of shadow and light,<br />digital stillness is
        born."
      </p>
      <p
        class="text-[#A39E93] tracking-[0.6em] text-[9px] md:text-[11px] uppercase mt-12 font-light"
      >
        II. The Vision
      </p>
    </div>

    <!-- ═══════════════════════════════════════════════
         STAGE III — THE ABANDONED BIRTH
         "Kelahiran yang Dibuang"
         scroll range: 0.31 → 0.415
         ═══════════════════════════════════════════════ -->
    <div
      id="stageStory1"
      class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none opacity-0 px-6 text-center will-change-transform"
    >
      <div
        class="relative w-32 h-32 md:w-44 md:h-44 mb-10 flex items-center justify-center"
      >
        <svg
          viewBox="0 0 200 200"
          class="absolute w-full h-full animate-[spin_40s_linear_infinite] opacity-30"
        >
          <circle
            cx="100"
            cy="100"
            r="80"
            fill="none"
            stroke="#C5A059"
            stroke-width="0.5"
            stroke-dasharray="4 8"></circle>
        </svg>
        <svg viewBox="0 0 200 200" class="absolute w-[85%] h-[85%] opacity-50">
          <g transform="translate(100,100)">
            <line
              x1="0"
              y1="-70"
              x2="0"
              y2="-55"
              stroke="#C5A059"
              stroke-width="1.5"></line>
            <line
              x1="0"
              y1="-70"
              x2="0"
              y2="-55"
              stroke="#C5A059"
              stroke-width="1.5"
              transform="rotate(30)"></line>
            <line
              x1="0"
              y1="-70"
              x2="0"
              y2="-55"
              stroke="#C5A059"
              stroke-width="1.5"
              transform="rotate(60)"></line>
            <line
              x1="0"
              y1="-70"
              x2="0"
              y2="-55"
              stroke="#C5A059"
              stroke-width="1.5"
              transform="rotate(90)"></line>
            <line
              x1="0"
              y1="-70"
              x2="0"
              y2="-55"
              stroke="#C5A059"
              stroke-width="1.5"
              transform="rotate(120)"></line>
            <line
              x1="0"
              y1="-70"
              x2="0"
              y2="-55"
              stroke="#C5A059"
              stroke-width="1.5"
              transform="rotate(150)"></line>
            <line
              x1="0"
              y1="-70"
              x2="0"
              y2="-55"
              stroke="#C5A059"
              stroke-width="1.5"
              transform="rotate(180)"></line>
            <line
              x1="0"
              y1="-70"
              x2="0"
              y2="-55"
              stroke="#C5A059"
              stroke-width="1.5"
              transform="rotate(210)"></line>
            <line
              x1="0"
              y1="-70"
              x2="0"
              y2="-55"
              stroke="#C5A059"
              stroke-width="1.5"
              transform="rotate(240)"></line>
            <line
              x1="0"
              y1="-70"
              x2="0"
              y2="-55"
              stroke="#C5A059"
              stroke-width="1.5"
              transform="rotate(270)"></line>
            <line
              x1="0"
              y1="-70"
              x2="0"
              y2="-55"
              stroke="#C5A059"
              stroke-width="1.5"
              transform="rotate(300)"></line>
            <line
              x1="0"
              y1="-70"
              x2="0"
              y2="-55"
              stroke="#C5A059"
              stroke-width="1.5"
              transform="rotate(330)"></line>
            <circle r="25" fill="none" stroke="#C5A059" stroke-width="1"
            ></circle>
            <circle r="3" fill="#C5A059"></circle>
          </g>
        </svg>
        <svg viewBox="0 0 200 60" class="absolute bottom-0 w-full opacity-30">
          <ellipse
            cx="100"
            cy="30"
            rx="70"
            ry="12"
            fill="none"
            stroke="#C5A059"
            stroke-width="1"></ellipse>
          <ellipse
            cx="100"
            cy="30"
            rx="50"
            ry="8"
            fill="none"
            stroke="#C5A059"
            stroke-width="0.5"></ellipse>
        </svg>
      </div>

      <span
        class="text-[#C5A059] tracking-[0.5em] text-sm md:text-base font-serif opacity-50 mb-4"
        >ꦏꦫ꧀ꦤ</span
      >
      <p
        class="text-[#F8F5F0] font-serif italic text-xl md:text-3xl leading-relaxed tracking-wide font-light max-w-2xl"
      >
        "Born armored in gold, kissed by Surya himself —<br />
        placed in a basket on the river's mercy<br />
        by the hands of the mother who could not keep him."
      </p>
      <p
        class="text-[#A39E93] text-base md:text-xl font-serif italic mt-6 max-w-xl opacity-70"
      >
        He did not choose his birth. He did not choose to be abandoned.<br />
        Yet he chose, every day thereafter, who he would become.
      </p>
      <p
        class="text-[#A39E93] tracking-[0.6em] text-[9px] md:text-[11px] uppercase mt-10 font-light"
      >
        III. Kelahiran yang Dibuang
      </p>
    </div>

    <!-- ═══════════════════════════════════════════════
         STAGE IV — SON OF THE CHARIOTEER
         "Sang Suta Putra"
         scroll range: 0.40 → 0.515
         ═══════════════════════════════════════════════ -->
    <div
      id="stageStory2"
      class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none opacity-0 px-6 text-center will-change-transform"
    >
      <div
        class="relative w-28 h-40 md:w-36 md:h-52 mb-10 flex items-center justify-center"
      >
        <svg
          viewBox="0 0 80 160"
          class="w-full h-full opacity-60 drop-shadow-[0_0_12px_rgba(197,160,89,0.4)]"
        >
          <path
            d="M 60 10 Q 10 80 60 150"
            fill="none"
            stroke="#C5A059"
            stroke-width="2"
            stroke-linecap="round"></path>
          <line
            x1="60"
            y1="10"
            x2="60"
            y2="150"
            stroke="#C5A059"
            stroke-width="0.8"
            opacity="0.6"></line>
          <line
            x1="15"
            y1="80"
            x2="72"
            y2="80"
            stroke="#C5A059"
            stroke-width="1.5"
            stroke-linecap="round"></line>
          <polygon points="72,80 65,76 65,84" fill="#C5A059"></polygon>
          <path
            d="M 15 80 L 10 74 M 15 80 L 10 86"
            stroke="#C5A059"
            stroke-width="1"
            fill="none"></path>
        </svg>
      </div>

      <span
        class="text-[#C5A059] tracking-[0.5em] text-sm md:text-base font-serif opacity-50 mb-4"
        >ꦱꦸꦠꦥꦸꦠꦿ</span
      >
      <p
        class="text-[#F8F5F0] font-serif italic text-xl md:text-3xl leading-relaxed tracking-wide font-light max-w-2xl"
      >
        "His arrow split the cloud before the masters could teach him.<br />
        His arm already knew what his blood was never told."
      </p>
      <p
        class="text-[#A39E93] text-base md:text-xl font-serif italic mt-6 max-w-xl opacity-70"
      >
        But when he stood in the tournament ring and dared to match Arjuna —<br
        />
        the crowd did not ask of his skill.<br />
        They asked of his father's name.<br />
        <span class="text-[#C5A059]/70">And laughed.</span>
      </p>
      <p
        class="text-[#F8F5F0] font-serif italic text-lg md:text-2xl mt-6 max-w-lg opacity-80"
      >
        "Greatness has never required permission.<br />
        But the world will always demand your papers."
      </p>
      <p
        class="text-[#A39E93] tracking-[0.6em] text-[9px] md:text-[11px] uppercase mt-10 font-light"
      >
        IV. Sang Suta Putra
      </p>
    </div>

    <!-- ═══════════════════════════════════════════════
         STAGE V — THE OATH OF ANGA
         "Sumpah Persaudaraan"
         scroll range: 0.49 → 0.615
         ═══════════════════════════════════════════════ -->
    <div
      id="stageStory3"
      class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none opacity-0 px-6 text-center will-change-transform"
    >
      <div class="relative mb-10 flex items-center justify-center">
        <svg
          viewBox="0 0 160 100"
          class="w-48 md:w-64 opacity-60 drop-shadow-[0_0_12px_rgba(197,160,89,0.4)]"
        >
          <path
            d="M 20 80 L 20 50 L 50 20 L 80 50 L 110 20 L 140 50 L 140 80 Z"
            fill="none"
            stroke="#C5A059"
            stroke-width="1.5"
            stroke-linejoin="round"></path>
          <circle
            cx="80"
            cy="50"
            r="5"
            fill="none"
            stroke="#C5A059"
            stroke-width="1.5"></circle>
          <circle cx="80" cy="50" r="2" fill="#C5A059"></circle>
          <path
            d="M 55 88 Q 80 70 105 88"
            fill="none"
            stroke="#C5A059"
            stroke-width="1"
            opacity="0.5"></path>
          <path
            d="M 65 90 Q 80 78 95 90"
            fill="none"
            stroke="#C5A059"
            stroke-width="0.8"
            opacity="0.4"></path>
          <path
            d="M 30 95 Q 50 85 55 75"
            fill="none"
            stroke="#C5A059"
            stroke-width="1.2"
            opacity="0.5"></path>
          <path
            d="M 130 95 Q 110 85 105 75"
            fill="none"
            stroke="#C5A059"
            stroke-width="1.2"
            opacity="0.5"></path>
        </svg>
      </div>

      <span
        class="text-[#C5A059] tracking-[0.5em] text-sm md:text-base font-serif opacity-50 mb-4"
        >ꦲꦁꦒ</span
      >
      <p
        class="text-[#F8F5F0] font-serif italic text-xl md:text-3xl leading-relaxed tracking-wide font-light max-w-2xl"
      >
        "When all the world named him lowborn,<br />
        one man stepped forward and placed a crown upon his head."
      </p>
      <p
        class="text-[#A39E93] text-base md:text-xl font-serif italic mt-6 max-w-xl opacity-70"
      >
        Duryodana asked nothing in return.<br />
        And so Karna gave everything —<br />
        not from debt, but from a gratitude<br />
        that became the marrow of his loyalty.
      </p>
      <p
        class="text-[#F8F5F0] font-serif italic text-lg md:text-2xl mt-6 max-w-lg opacity-80"
      >
        "A vow born in the hour of humiliation<br />
        is the vow that outlives death itself."
      </p>
      <p
        class="text-[#A39E93] tracking-[0.6em] text-[9px] md:text-[11px] uppercase mt-10 font-light"
      >
        V. Sumpah Persaudaraan
      </p>
    </div>

    <!-- ═══════════════════════════════════════════════
         STAGE VI — THE STRIPPING OF THE ARMOR
         "Pelucutan Kavacha Kundala"
         scroll range: 0.58 → 0.705
         ═══════════════════════════════════════════════ -->
    <div
      id="stageStory4"
      class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none opacity-0 px-6 text-center will-change-transform"
    >
      <div
