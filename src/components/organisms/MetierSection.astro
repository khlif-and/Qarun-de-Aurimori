---
---

<section class="w-full bg-[#fbfcfd] py-24 md:py-32 flex justify-center px-6" id="services">
  <div class="max-w-[1200px] w-full flex flex-col items-center gap-16 md:gap-20">
    
    <!-- Section Header -->
    <div class="flex flex-col items-center">
      <h2 class="text-4xl md:text-[42px] text-[#1e293b] font-serif mb-5" style="font-family: 'Playfair Display', serif;">
        Our Metier
      </h2>
      <div class="w-10 h-[3px] bg-[#c1e8f9] rounded-full"></div>
    </div>

    <!-- 3-Column Services Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-14 md:gap-6 lg:gap-12 w-full">
      
      <!-- Service 1: Digital Architecture -->
      <div class="flex flex-col items-center text-center group cursor-pointer">
        <div class="w-[84px] h-[84px] bg-[#f0f9ff] text-[#3cbce6] rounded-2xl mb-7 flex items-center justify-center transform group-hover:-translate-y-2 transition-transform duration-500 shadow-sm border border-sky-100/40">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="m12 3-5.5 18"></path>
            <path d="m12 3 5.5 18"></path>
            <path d="M10.1 12h3.8"></path>
            <circle cx="12" cy="3" r="1.5"></circle>
          </svg>
        </div>
        <h3 class="text-[22px] text-[#1e293b] font-serif italic mb-4" style="font-family: 'Playfair Display', serif;">Digital Architecture</h3>
        <p class="text-[#64748b] text-[15px] leading-[1.8] px-4">
          Designing online ecosystems that function with the precision of structural engineering.
        </p>
      </div>

      <!-- Service 2: Visual Storytelling -->
      <div class="flex flex-col items-center text-center group cursor-pointer">
        <div class="w-[84px] h-[84px] bg-[#f0f9ff] text-[#3cbce6] rounded-2xl mb-7 flex items-center justify-center transform group-hover:-translate-y-2 transition-transform duration-500 shadow-sm border border-sky-100/40">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H12"></path>
            <path d="M20 19.5v-15A2.5 2.5 0 0 0 17.5 2H12"></path>
            <line x1="12" y1="2" x2="12" y2="22"></line>
            <path d="M4 19.5a2.5 2.5 0 0 1 2.5-2.5H12"></path>
            <path d="M20 19.5a2.5 2.5 0 0 0-2.5-2.5H12"></path>
          </svg>
        </div>
        <h3 class="text-[22px] text-[#1e293b] font-serif italic mb-4" style="font-family: 'Playfair Display', serif;">Visual Storytelling</h3>
        <p class="text-[#64748b] text-[15px] leading-[1.8] px-4">
          Curating narratives through cinematic motion to tell stories that resonate on a primal level.
        </p>
      </div>

      <!-- Service 3: Creative Direction -->
      <div class="flex flex-col items-center text-center group cursor-pointer">
        <div class="w-[84px] h-[84px] bg-[#f0f9ff] text-[#3cbce6] rounded-2xl mb-7 flex items-center justify-center transform group-hover:-translate-y-2 transition-transform duration-500 shadow-sm border border-sky-100/40">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
            <circle cx="12" cy="12" r="4"></circle>
          </svg>
        </div>
        <h3 class="text-[22px] text-[#1e293b] font-serif italic mb-4" style="font-family: 'Playfair Display', serif;">Creative Direction</h3>
        <p class="text-[#64748b] text-[15px] leading-[1.8] px-4">
          Guiding brands through the fog of the mundane toward a vision of ethereal clarity.
        </p>
      </div>

    </div>
  </div>
</section>
