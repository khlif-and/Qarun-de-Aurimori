---
---

<section class="w-full bg-[#fbfcfd] py-24 md:py-32 px-6 flex justify-center border-t border-slate-100/50">
  <div class="max-w-[1000px] w-full flex flex-col md:flex-row gap-16 md:gap-24">
    
    <!-- Left: Title Area -->
    <div class="w-full md:w-[35%] flex flex-col">
      <h2 class="text-4xl md:text-[42px] text-[#1e293b] font-serif mb-6 leading-[1.2]" style="font-family: 'Playfair Display', serif;">
        The Evolution<br class="hidden md:block" /> of Form
      </h2>
      <p class="text-[#64748b] text-[15px] md:text-[16px] leading-[1.7] max-w-[280px]">
        A chronological tracing of our pursuit for the eternal in the ephemeral.
      </p>
    </div>

    <!-- Right: Timeline -->
    <div class="w-full md:w-[65%] relative mt-4 md:mt-0">
      <!-- Vertical Line -->
      <div class="absolute left-0 lg:left-[1px] top-2 bottom-6 w-[1px] bg-sky-200/60"></div>

      <div class="flex flex-col gap-12 md:gap-14">
        
        <!-- Timeline Item 1 -->
        <div class="relative pl-8 md:pl-12">
          <!-- Dot -->
          <div class="absolute left-[-4px] lg:left-[-3px] top-1.5 w-[9px] h-[9px] rounded-full bg-[#3cbce6] ring-[6px] ring-[#fbfcfd]"></div>
          
          <div class="flex flex-col gap-2">
            <span class="text-[#3cbce6] text-[10px] md:text-[11px] font-bold tracking-[0.2em] uppercase">2018 — The Genesis</span>
            <h3 class="text-[22px] md:text-[24px] text-[#1e293b] font-serif mt-1" style="font-family: 'Playfair Display', serif;">Geometric Minimalism</h3>
            <p class="text-[#64748b] text-[15px] md:text-[16px] leading-[1.7] mt-1 max-w-[500px]">
              The studio founded with a focus on pure Euclidean forms and the stark interplay of black and white imagery.
            </p>
          </div>
        </div>

        <!-- Timeline Item 2 -->
        <div class="relative pl-8 md:pl-12">
          <!-- Dot -->
          <div class="absolute left-[-4px] lg:left-[-3px] top-1.5 w-[9px] h-[9px] rounded-full bg-slate-300 ring-[6px] ring-[#fbfcfd]"></div>
          
          <div class="flex flex-col gap-2">
            <span class="text-[#3cbce6] text-[10px] md:text-[11px] font-bold tracking-[0.2em] uppercase">2020 — The Shift</span>
            <h3 class="text-[22px] md:text-[24px] text-[#1e293b] font-serif mt-1" style="font-family: 'Playfair Display', serif;">Atmospheric Depth</h3>
            <p class="text-[#64748b] text-[15px] md:text-[16px] leading-[1.7] mt-1 max-w-[500px]">
              Introduction of volumetric lighting and particle systems to create 'breathing' digital environments.
            </p>
          </div>
        </div>

        <!-- Timeline Item 3 -->
        <div class="relative pl-8 md:pl-12">
          <!-- Dot -->
          <div class="absolute left-[-4px] lg:left-[-3px] top-1.5 w-[9px] h-[9px] rounded-full bg-slate-300 ring-[6px] ring-[#fbfcfd]"></div>
          
          <div class="flex flex-col gap-2">
            <span class="text-[#3cbce6] text-[10px] md:text-[11px] font-bold tracking-[0.2em] uppercase">2023 — The Present</span>
            <h3 class="text-[22px] md:text-[24px] text-[#1e293b] font-serif mt-1" style="font-family: 'Playfair Display', serif;">Material Archeology</h3>
            <p class="text-[#64748b] text-[15px] md:text-[16px] leading-[1.7] mt-1 max-w-[500px]">
              Current focus on high-fidelity texture and the simulation of physical decay in virtual spaces.
            </p>
          </div>
        </div>

      </div>
    </div>
    
  </div>
</section>
