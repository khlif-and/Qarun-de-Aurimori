---
---

<section class="w-full bg-[#f4f7f9] py-24 md:py-32 px-6 flex justify-center border-t border-slate-100/50">
  <div class="max-w-[1200px] w-full flex flex-col items-center">
    
    <!-- Section Header  -->
    <div class="flex flex-col items-center text-center mb-16 md:mb-24">
      <span class="text-[#3cbce6] text-[11px] md:text-xs font-bold tracking-[0.25em] uppercase mb-4">Phenomenology</span>
      <h2 class="text-4xl md:text-[42px] text-[#1e293b] font-serif mb-5" style="font-family: 'Playfair Display', serif;">
        The Sensory Approach
      </h2>
      <p class="text-[#64748b] text-[16px] md:text-[17px] leading-[1.8] font-medium max-w-[700px] px-4">
        Designing for the senses requires an understanding of the invisible—the weight of air, the grain of silence, and the temperature of color.
      </p>
    </div>

    <!-- 5-Column Senses Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-10 md:gap-x-6 md:gap-y-12 lg:gap-8 w-full">
      
      <!-- Sense 1: Sight -->
      <div class="flex flex-col items-center text-center group cursor-pointer">
        <div class="w-[64px] h-[64px] bg-[#f0f9ff] text-[#3cbce6] rounded-2xl mb-5 flex items-center justify-center transform group-hover:-translate-y-2 transition-transform duration-500 shadow-sm border border-sky-100/50">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path>
            <circle cx="12" cy="12" r="3"></circle>
          </svg>
        </div>
        <h3 class="text-[20px] text-[#1e293b] font-serif italic mb-3" style="font-family: 'Playfair Display', serif;">Sight</h3>
        <p class="text-[#94a3b8] text-[13px] md:text-[14px] leading-[1.6]">
          The soft gradient of a dawn sky.
        </p>
      </div>

      <!-- Sense 2: Sound -->
      <div class="flex flex-col items-center text-center group cursor-pointer">
        <div class="w-[64px] h-[64px] bg-[#f0f9ff] text-[#3cbce6] rounded-2xl mb-5 flex items-center justify-center transform group-hover:-translate-y-2 transition-transform duration-500 shadow-sm border border-sky-100/50">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 8.5a6.5 6.5 0 1 1 13 0c0 6-6 6-6 10a1 1 0 0 1-1 1h-2a1 1 0 0 1-1-1v-2.5"></path>
            <path d="M16 8.5A2.5 2.5 0 0 1 13.5 11"></path>
          </svg>
        </div>
        <h3 class="text-[20px] text-[#1e293b] font-serif italic mb-3" style="font-family: 'Playfair Display', serif;">Sound</h3>
        <p class="text-[#94a3b8] text-[13px] md:text-[14px] leading-[1.6]">
          The hollow resonance of high ceilings.
        </p>
      </div>

      <!-- Sense 3: Touch -->
      <div class="flex flex-col items-center text-center group cursor-pointer">
        <div class="w-[64px] h-[64px] bg-[#f0f9ff] text-[#3cbce6] rounded-2xl mb-5 flex items-center justify-center transform group-hover:-translate-y-2 transition-transform duration-500 shadow-sm border border-sky-100/50">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 14a8 8 0 0 1-8 8M18 11v-1a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"></path>
            <path d="M14 10V9a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v1"></path>
            <path d="M10 9.5V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v10"></path>
            <path d="M18 11a2 2 0 1 1 4 0v3a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"></path>
          </svg>
        </div>
        <h3 class="text-[20px] text-[#1e293b] font-serif italic mb-3" style="font-family: 'Playfair Display', serif;">Touch</h3>
        <p class="text-[#94a3b8] text-[13px] md:text-[14px] leading-[1.6]">
          The coarse grit of weathered stone.
        </p>
      </div>

      <!-- Sense 4: Scent -->
      <div class="flex flex-col items-center text-center group cursor-pointer">
        <div class="w-[64px] h-[64px] bg-[#f0f9ff] text-[#3cbce6] rounded-2xl mb-5 flex items-center justify-center transform group-hover:-translate-y-2 transition-transform duration-500 shadow-sm border border-sky-100/50">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M17.7 7.7a2.5 2.5 0 1 1 1.8 4.3H2"></path>
            <path d="M9.6 4.6A2 2 0 1 1 11 8H2"></path>
            <path d="M12.6 19.4A2 2 0 1 0 14 16H2"></path>
          </svg>
        </div>
        <h3 class="text-[20px] text-[#1e293b] font-serif italic mb-3" style="font-family: 'Playfair Display', serif;">Scent</h3>
        <p class="text-[#94a3b8] text-[13px] md:text-[14px] leading-[1.6]">
          The memory of rain on warm dust.
        </p>
      </div>

      <!-- Sense 5: Presence -->
      <div class="flex flex-col items-center text-center group cursor-pointer lg:col-span-1 col-span-2 md:col-span-1">
        <div class="w-[64px] h-[64px] bg-[#f0f9ff] text-[#3cbce6] rounded-2xl mb-5 flex items-center justify-center transform group-hover:-translate-y-2 transition-transform duration-500 shadow-sm border border-sky-100/50">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
          </svg>
        </div>
        <h3 class="text-[20px] text-[#1e293b] font-serif italic mb-3" style="font-family: 'Playfair Display', serif;">Presence</h3>
        <p class="text-[#94a3b8] text-[13px] md:text-[14px] leading-[1.6]">
          The lingering ghost of a narrative.
        </p>
      </div>

    </div>
  </div>
</section>
