---
---

<section class="w-full bg-[#fbfcfd] py-20 md:py-32 flex justify-center px-6 border-t border-slate-100/50">
  <div class="max-w-[1200px] w-full flex flex-col gap-10 md:gap-14">
    
    <!-- Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end gap-4 w-full px-2">
      <h2 class="text-3xl md:text-[38px] lg:text-[40px] text-[#1e293b] font-serif italic" style="font-family: 'Playfair Display', serif;">
        Visual Fragments
      </h2>
      <span class="text-slate-400 text-[13px] md:text-sm font-medium tracking-wide">
        Selected Process Work
      </span>
    </div>

    <!-- Image Grid - Staggered Layout -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5 lg:gap-6 items-center">
      
      <!-- Img 1 -->
      <div class="w-full aspect-[4/5] rounded-xl overflow-hidden shadow-xl shadow-slate-200/60 transform hover:-translate-y-2 transition-transform duration-700">
        <img src="https://images.unsplash.com/photo-1549490349-8643362247b5?q=80&w=800&auto=format&fit=crop" alt="Light and shadow" class="w-full h-full object-cover grayscale opacity-90 hover:opacity-100 transition-opacity duration-700" />
      </div>

      <!-- Img 2: shifted down -->
      <div class="w-full aspect-[4/5] rounded-xl overflow-hidden shadow-xl shadow-slate-200/60 transform translate-y-6 md:translate-y-8 hover:-translate-y-0 transition-transform duration-700">
        <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?q=80&w=800&auto=format&fit=crop" alt="Architectural symmetry" class="w-full h-full object-cover grayscale opacity-90 hover:opacity-100 transition-opacity duration-700" />
      </div>

      <!-- Img 3 -->
      <div class="w-full aspect-square rounded-xl overflow-hidden shadow-xl shadow-slate-200/60 transform hover:-translate-y-2 transition-transform duration-700 mt-8 md:mt-0">
        <img src="https://images.unsplash.com/photo-1618221195710-dd6b41faaea6?q=80&w=800&auto=format&fit=crop" alt="Minimalist interior" class="w-full h-full object-cover grayscale opacity-90 hover:opacity-100 transition-opacity duration-700" />
      </div>

      <!-- Img 4: shorter, shifted slightly -->
      <div class="w-full aspect-[4/3] rounded-xl overflow-hidden shadow-xl shadow-slate-200/60 transform translate-y-4 hover:-translate-y-1 transition-transform duration-700 mt-8 md:mt-0">
        <img src="https://images.unsplash.com/photo-1464822759023-fed622ff2c3b?q=80&w=800&auto=format&fit=crop" alt="Abstract landscape geometry" class="w-full h-full object-cover grayscale opacity-90 hover:opacity-100 transition-opacity duration-700" />
      </div>

    </div>

  </div>
</section>
