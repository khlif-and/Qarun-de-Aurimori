---
---

<section class="relative w-full min-h-[calc(100vh-80px)] flex flex-col items-center justify-center overflow-hidden bg-[#fbfcfd]">
  
  <!-- Subtle Background Decorations (Ethereal feel) -->
  <div class="absolute top-1/4 left-[10%] w-[400px] h-[400px] bg-slate-100 rounded-full mix-blend-multiply filter blur-[100px] opacity-70"></div>
  <div class="absolute bottom-1/4 right-[5%] w-[500px] h-[500px] bg-sky-50 rounded-full mix-blend-multiply filter blur-[120px] opacity-60"></div>

  <div class="relative z-10 flex flex-col items-center px-4 w-full">
    <!-- Est Badge -->
    <div class="mb-10 px-5 py-1.5 rounded-full bg-[#edf6fc] border border-sky-100/50 shadow-sm flex items-center justify-center">
      <span class="text-xs font-bold tracking-[0.2em] text-[#3cbce6] uppercase">Est. MMXXIV</span>
    </div>

    <!-- Main Headline with Serif Font -->
    <h1 class="text-6xl md:text-8xl lg:text-[110px] text-center text-[#1e293b] mb-8 tracking-tight leading-[1.1] transition-all" style="font-family: 'Playfair Display', serif;">
      Qarun <span class="text-[#3cbce6] italic font-normal tracking-normal pr-2">de</span> Aurimori
    </h1>

    <!-- Subheadline -->
    <p class="text-slate-500 text-center max-w-[650px] text-[17px] md:text-[19px] mb-20 leading-[1.7] font-light">
      A Creative Visionary Crafting Ethereal Digital Experiences and<br class="hidden md:block" /> Architectural Narratives for the Modern Soul.
    </p>

    <!-- Scroll Down Indicator -->
    <div class="absolute -bottom-12 md:-bottom-20 animate-bounce cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-[#3cbce6] opacity-70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </div>
  </div>
</section>
