---
import { Image } from 'astro:assets';
import logoImage from '../../assets/logo.png';
---

<a href="/" class="flex items-center gap-3">
  <div class="h-12 md:h-16 flex items-center justify-center">
    <!-- Menghapus efek scale agar gambar tidak meleber dan menabrak teks -->
    <Image src={logoImage} alt="Qarun de Aurimori Logo" class="object-contain w-auto h-full" />
  </div>
  <span class="font-bold text-[#1a202c] text-xl tracking-tight">Qarun de Aurimori</span>
</a>
